rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic rules to allow authenticated users to access the system
    
    match /Users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /BillingAccounts/{accountId} {
      allow read, write: if request.auth != null;
    }
    
    match /Meters/{meterId} {
      allow read, write: if request.auth != null;
    }
    
    match /Investigators/{investigatorId} {
      allow read, write: if request.auth != null;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
